import Database from 'better-sqlite3';
import { v4 as uuidv4 } from 'uuid';
import { join } from 'path';
import { readFileSync } from 'fs';

let db = null;

export function getDatabase() {
  if (!db) {
    // Database path - will be in app data folder
    const dbPath = join(process.cwd(), 'dalkiran-pos.db');
    db = new Database(dbPath);

    // Enable foreign keys
    db.pragma('foreign_keys = ON');

    // Initialize schema
    initializeSchema();
  }

  return db;
}

function initializeSchema() {
  const schemaPath = join(process.cwd(), 'src', 'lib', 'db', 'schema.sql');
  const schema = readFileSync(schemaPath, 'utf-8');

  // Execute schema
  db.exec(schema);

  // Insert default device config if not exists
  const configExists = db.prepare('SELECT COUNT(*) as count FROM device_config').get();
  if (configExists.count === 0) {
    db.prepare(`
      INSERT INTO device_config (id, is_activated, api_url)
      VALUES (1, 0, 'http://localhost:3000')
    `).run();
  }
}

// Device Configuration
export const deviceConfigRepo = {
  get() {
    return db.prepare('SELECT * FROM device_config WHERE id = 1').get();
  },

  update(data) {
    const stmt = db.prepare(`
      UPDATE device_config
      SET device_id = ?, store_id = ?, store_name = ?,
          is_activated = ?, activated_at = ?, api_url = ?
      WHERE id = 1
    `);

    return stmt.run(
      data.device_id,
      data.store_id,
      data.store_name,
      data.is_activated ? 1 : 0,
      data.activated_at,
      data.api_url
    );
  },

  updateLastSync() {
    const stmt = db.prepare('UPDATE device_config SET last_sync_at = ? WHERE id = 1');
    return stmt.run(new Date().toISOString());
  }
};

// Users
export const userRepo = {
  findByUsername(username) {
    return db.prepare('SELECT * FROM users WHERE username = ?').get(username);
  },

  upsert(user) {
    const stmt = db.prepare(`
      INSERT INTO users (id, username, password, full_name, role, store_id, is_active, created_at, updated_at)
      VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
      ON CONFLICT(id) DO UPDATE SET
        username = excluded.username,
        password = excluded.password,
        full_name = excluded.full_name,
        role = excluded.role,
        is_active = excluded.is_active,
        updated_at = excluded.updated_at
    `);

    return stmt.run(
      user.id,
      user.username,
      user.password,
      user.full_name,
      user.role,
      user.store_id,
      user.is_active ? 1 : 0,
      user.created_at || new Date().toISOString(),
      user.updated_at || new Date().toISOString()
    );
  },

  findAll() {
    return db.prepare('SELECT * FROM users WHERE is_active = 1').all();
  }
};

// Products
export const productRepo = {
  findByBarcode(barcode) {
    return db.prepare('SELECT * FROM products WHERE barcode = ? AND is_active = 1').get(barcode);
  },

  findAll() {
    return db.prepare('SELECT * FROM products WHERE is_active = 1').all();
  },

  upsert(product) {
    const stmt = db.prepare(`
      INSERT INTO products (id, barcode, name, description, category_id, price, cost_price, minimum_stock, is_active, created_at, updated_at)
      VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
      ON CONFLICT(id) DO UPDATE SET
        barcode = excluded.barcode,
        name = excluded.name,
        description = excluded.description,
        category_id = excluded.category_id,
        price = excluded.price,
        cost_price = excluded.cost_price,
        minimum_stock = excluded.minimum_stock,
        is_active = excluded.is_active,
        updated_at = excluded.updated_at
    `);

    return stmt.run(
      product.id,
      product.barcode,
      product.name,
      product.description,
      product.category_id,
      product.price,
      product.cost_price || 0,
      product.minimum_stock || 0,
      product.is_active ? 1 : 0,
      product.created_at || new Date().toISOString(),
      product.updated_at || new Date().toISOString()
    );
  }
};

// Categories
export const categoryRepo = {
  findAll() {
    return db.prepare('SELECT * FROM categories WHERE is_active = 1').all();
  },

  upsert(category) {
    const stmt = db.prepare(`
      INSERT INTO categories (id, name, description, is_active, created_at, updated_at)
      VALUES (?, ?, ?, ?, ?, ?)
      ON CONFLICT(id) DO UPDATE SET
        name = excluded.name,
        description = excluded.description,
        is_active = excluded.is_active,
        updated_at = excluded.updated_at
    `);

    return stmt.run(
      category.id,
      category.name,
      category.description,
      category.is_active ? 1 : 0,
      category.created_at || new Date().toISOString(),
      category.updated_at || new Date().toISOString()
    );
  }
};

// Stocks
export const stockRepo = {
  findByProduct(productId, storeId) {
    return db.prepare('SELECT * FROM stocks WHERE product_id = ? AND store_id = ?').get(productId, storeId);
  },

  upsert(stock) {
    const stmt = db.prepare(`
      INSERT INTO stocks (id, product_id, store_id, quantity, created_at, updated_at)
      VALUES (?, ?, ?, ?, ?, ?)
      ON CONFLICT(product_id, store_id) DO UPDATE SET
        quantity = excluded.quantity,
        updated_at = excluded.updated_at
    `);

    return stmt.run(
      stock.id || uuidv4(),
      stock.product_id,
      stock.store_id,
      stock.quantity,
      stock.created_at || new Date().toISOString(),
      new Date().toISOString()
    );
  },

  updateQuantity(productId, storeId, delta) {
    const stmt = db.prepare(`
      UPDATE stocks
      SET quantity = quantity + ?, updated_at = ?
      WHERE product_id = ? AND store_id = ?
    `);

    return stmt.run(delta, new Date().toISOString(), productId, storeId);
  }
};

// Shifts
export const shiftRepo = {
  getCurrentShift(deviceId) {
    return db.prepare('SELECT * FROM shifts WHERE device_id = ? AND is_open = 1').get(deviceId);
  },

  create(shift) {
    const id = uuidv4();
    const stmt = db.prepare(`
      INSERT INTO shifts (id, store_id, user_id, device_id, opening_cash, opened_at, is_open, synced, created_at, updated_at)
      VALUES (?, ?, ?, ?, ?, ?, 1, 0, ?, ?)
    `);

    const now = new Date().toISOString();
    stmt.run(
      id,
      shift.store_id,
      shift.user_id,
      shift.device_id,
      shift.opening_cash,
      shift.opened_at || now,
      now,
      now
    );

    return { id, ...shift };
  },

  close(shiftId, closingCash, expectedCash, cashDifference) {
    const stmt = db.prepare(`
      UPDATE shifts
      SET closing_cash = ?, expected_cash = ?, cash_difference = ?,
          closed_at = ?, is_open = 0, updated_at = ?
      WHERE id = ?
    `);

    const now = new Date().toISOString();
    return stmt.run(closingCash, expectedCash, cashDifference, now, now, shiftId);
  }
};

// Sales
export const saleRepo = {
  create(sale, items, payments) {
    const transaction = db.transaction(() => {
      const saleId = uuidv4();
      const now = new Date().toISOString();

      // Create sale
      const saleStmt = db.prepare(`
        INSERT INTO sales (id, receipt_number, store_id, user_id, device_id, total_amount, discount_amount, final_amount, shift_id, synced, created_at)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, 0, ?)
      `);

      saleStmt.run(
        saleId,
        sale.receipt_number,
        sale.store_id,
        sale.user_id,
        sale.device_id,
        sale.total_amount,
        sale.discount_amount || 0,
        sale.final_amount,
        sale.shift_id,
        now
      );

      // Create sale items
      const itemStmt = db.prepare(`
        INSERT INTO sale_items (id, sale_id, product_id, product_name, barcode, quantity, unit_price, total_price, created_at)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
      `);

      for (const item of items) {
        const itemId = uuidv4();
        itemStmt.run(
          itemId,
          saleId,
          item.product_id,
          item.product_name,
          item.barcode,
          item.quantity,
          item.unit_price,
          item.total_price,
          now
        );

        // Update stock
        stockRepo.updateQuantity(item.product_id, sale.store_id, -item.quantity);
      }

      // Create payments
      const paymentStmt = db.prepare(`
        INSERT INTO payments (id, sale_id, method, amount, created_at)
        VALUES (?, ?, ?, ?, ?)
      `);

      for (const payment of payments) {
        const paymentId = uuidv4();
        paymentStmt.run(paymentId, saleId, payment.method, payment.amount, now);
      }

      return saleId;
    });

    return transaction();
  },

  findUnsyncedSales() {
    const sales = db.prepare('SELECT * FROM sales WHERE synced = 0').all();

    for (const sale of sales) {
      sale.items = db.prepare('SELECT * FROM sale_items WHERE sale_id = ?').all(sale.id);
      sale.payments = db.prepare('SELECT * FROM payments WHERE sale_id = ?').all(sale.id);
    }

    return sales;
  },

  markAsSynced(saleIds) {
    const stmt = db.prepare('UPDATE sales SET synced = 1 WHERE id = ?');
    const transaction = db.transaction((ids) => {
      for (const id of ids) {
        stmt.run(id);
      }
    });

    transaction(saleIds);
  }
};

// Refunds
export const refundRepo = {
  getAll() {
    return db.prepare('SELECT * FROM refunds ORDER BY created_at DESC').all();
  },

  create(refund) {
    const id = uuidv4();
    const now = new Date().toISOString();
    const stmt = db.prepare(`
      INSERT INTO refunds (id, sale_id, reason, amount, created_at)
      VALUES (?, ?, ?, ?, ?)
    `);
    stmt.run(id, refund.sale_id, refund.reason, refund.amount, now);
    return id;
  }
};

// Audit Logs
export const auditLogRepo = {
  getAll() {
    return db.prepare('SELECT * FROM audit_logs ORDER BY created_at DESC LIMIT 100').all();
  },

  create(log) {
    const id = uuidv4();
    const now = new Date().toISOString();
    const stmt = db.prepare(`
      INSERT INTO audit_logs (id, user_id, action_type, details, created_at)
      VALUES (?, ?, ?, ?, ?)
    `);
    stmt.run(id, log.user_id, log.action_type, log.details, now);
    return id;
  }
};

// Stock Adjustments
export const stockAdjustmentRepo = {
  getAll() {
    return db.prepare('SELECT * FROM stock_adjustments ORDER BY created_at DESC').all();
  },

  create(adjustment) {
    const id = uuidv4();
    const now = new Date().toISOString();
    const stmt = db.prepare(`
      INSERT INTO stock_adjustments (id, product_id, store_id, quantity_change, reason, created_at)
      VALUES (?, ?, ?, ?, ?, ?)
    `);
    stmt.run(id, adjustment.product_id, adjustment.store_id, adjustment.quantity_change, adjustment.reason, now);
    return id;
  }
};

// Initialize database
getDatabase();
